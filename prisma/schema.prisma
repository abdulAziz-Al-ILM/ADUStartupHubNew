generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === ENUMLAR (O'zgarmas qiymatlar) ===

enum Role {
  ADMIN
  LEADER    
  TUTOR
  STUDENT
}

enum Profession {
  IT_ENGINEER
  UI_UX_DESIGNER
  PROJECT_MANAGER
  MARKETOLOG
  ECONOMIST
  BIOLOGIST
  ECOLOGIST
  PEDAGOGUE
  DOCTOR
  PHARMACIST
  LINGUIST
  JURIST
  AGRONOMIST
  CHEMIST
  PHYSICIST
}

// YANGILANGAN STARTAP HOLATLARI
enum ProjectStatus {
  TEAM_BUILDING       // Jamoa yig'moqda
  MVP_PREPARATION     // MVP tayyorlanmoqda
  NEED_INVESTMENT     // MVP tayyor, pul/sarmoya kerak
  READY_FOR_MARKET    // Bozorga olib chiqish kerak
  MARKET_TESTING      // Bozorga olib chiqildi, sinovda
  IN_MARKET           // Bozorda ishlamoqda
  FINISHED            // Loyiha tugatildi
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// === JADVALLAR (MODELS) ===

model User {
  id               String      @id @default(uuid())
  email            String      @unique
  
  // Asosiy profil ma'lumotlari
  nickname         String?     @unique
  nicknameSetAt    DateTime?   
  avatarSticker    Int         @default(1) 
  profession       Profession?
  aboutMe          String?     @db.Text
  isEmailPublic    Boolean     @default(false)

  // YANGI: Rezyume (Profil) ma'lumotlari (Barchasi ixtiyoriy)
  firstName        String?     // Haqiqiy ism
  age              Int?        // Yoshi
  faculty          String?     // Fakultet/Yo'nalish
  course           Int?        // Kursi
  principles       String?     @db.Text // Prinsiplari (Tartib, estetika, tezlik...)
  weeklyHours      Int?        // Haftasiga loyihaga ajrata oladigan vaqti (soat)
  dailyHours       Int?        // Kuniga ajrata oladigan vaqti (soat)
  
  // Autentifikatsiya va Xavfsizlik
  otpCode          String?
  otpExpiresAt     DateTime?
  role             Role        @default(STUDENT)
  
  // Telegram va Admin xavfsizligi
  telegramId       String?     @unique
  tgUsername       String?
  adminPassword    String?     
  adminAuthCode    String?
  adminCodeExp     DateTime?
  trustedDevices   String[]    
  
  // Zirhli eshik
  invitedById      String?
  invitedBy        User?       @relation("TutorInvites", fields: [invitedById], references: [id])
  invitedUsers     User[]      @relation("TutorInvites")
  
  // Limitlar
  canCreateProject Boolean     @default(true) 
  dailyMsgCount    Int         @default(0)    
  dailyIdeaCount   Int         @default(0)    
  dailyProfileEdits Int        @default(0)    // YANGI: Kuniga profil tahrirlash limiti (Maks: 2)
  lastResetDate    DateTime    @default(now()) 

  // Aloqalar
  projects         Project[]
  resumes          Resume[]
  problems         Problem[]
  requests         Request[]   @relation("Sender")
  receivedRequests Request[]   @relation("Receiver")
  following        Follow[]    @relation("Follower")
  followers        Follow[]    @relation("Following")
  sentMessages     Message[]   @relation("Sender")
  receivedMessages Message[]   @relation("Receiver")

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model InviteCode {
  id        String   @id @default(uuid())
  code      String   @unique
  tutorId   String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Project {
  id              String        @id @default(uuid())
  title           String
  goal            String        @db.Text 
  reason          String        @db.Text 
  benefit         String        @db.Text // Manfaati (nonprofit/profit va jamoa uchun)
  
  // YANGI: Loyiha talablari va muhiti
  telegramLink    String?       // Loyihaning yopiq Telegram guruhi havolasi
  currentProblems String?       @db.Text // Loyihada hozir mavjud muammolar
  deadline        String?       // Qancha muddatga reja qilingan
  
  category        Profession    
  status          ProjectStatus @default(TEAM_BUILDING)
  cancelReason    String?       @db.Text // Tugatilish sababi (AI tomonidan tozalangan)
  
  authorId        String
  author          User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  requests        Request[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Problem {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  isDraft     Boolean  @default(false) 
  aiFeedback  String?  @db.Text        
  
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

model Resume {
  id          String     @id @default(uuid())
  title       String
  skills      String[]
  category    Profession
  
  authorId    String
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  requests    Request[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// Startapga qo'shilish yoki Mutaxassisga taklif yuborish
model Request {
  id              String        @id @default(uuid())
  status          RequestStatus @default(PENDING)
  
  // YANGI: Ariza to'ldirilgandagi javoblar (Vizitka uchun)
  expectedBenefit String?       @db.Text // Talaba loyihadan nima kutyapti / Loyiha talabadan
  timeCommitment  String?       // Qancha vaqt ajrata oladi
  
  senderId        String
  sender          User          @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  
  receiverId      String?       // Mutaxassisga to'g'ridan-to'g'ri taklif yuborish uchun
  receiver        User?         @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  
  projectId       String?
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  resumeId        String?
  resume          Resume?       @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// YANGI: Qo'llanmalar (Startaplar va vositalar uchun)
model Manual {
  id          String   @id @default(uuid())
  title       String
  link        String   @unique
  isSafe      Boolean  @default(true) // Antivirus API orqali tekshirilgan
  addedBy     String   // ADMIN yoki LEADER ID'si
  createdAt   DateTime @default(now())
}

// YANGI: ILM Mizan Yangiliklari
model News {
  id          String   @id @default(uuid())
  title       String
  content     String   @db.Text
  link        String?  // Biron bir havola biriktirish uchun
  createdAt   DateTime @default(now())
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model Message {
  id          String   @id @default(uuid())
  text        String   @db.Text 
  senderId    String
  receiverId  String
  sender      User     @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User     @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model SystemSettings {
  id             Int      @id @default(1)
  isSystemOpen   Boolean  @default(false)
  updatedAt      DateTime @updatedAt
}
