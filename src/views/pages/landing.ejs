<!DOCTYPE html>
<html lang="uz" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ADU Startup Hub - Kelajakni Quramiz</title>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0b1120">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        darkBg: '#0b1120',
                        darkCard: '#151e32',
                        darkBorder: '#1e293b',
                    },
                    animation: {
                        'blob': 'blob 7s infinite',
                        'fade-in-up': 'fadeInUp 1s ease-out forwards',
                        'bounce-slow': 'bounce 3s infinite',
                    },
                    keyframes: {
                        blob: {
                            '0%': { transform: 'translate(0px, 0px) scale(1)' },
                            '33%': { transform: 'translate(30px, -50px) scale(1.1)' },
                            '66%': { transform: 'translate(-20px, 20px) scale(0.9)' },
                            '100%': { transform: 'translate(0px, 0px) scale(1)' },
                        },
                        fadeInUp: {
                            '0%': { opacity: '0', transform: 'translateY(20px)' },
                            '100%': { opacity: '1', transform: 'translateY(0)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        .bg-grid-pattern {
            background-image: radial-gradient(rgba(148, 163, 184, 0.15) 1px, transparent 1px);
            background-size: 32px 32px;
        }
        .text-glow {
            text-shadow: 0 0 40px rgba(59, 130, 246, 0.5);
        }
        .glass-nav {
            background: rgba(11, 17, 32, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(30, 41, 59, 0.5);
        }
        .bento-card {
            transition: all 0.3s ease;
        }
        .bento-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px -15px rgba(59, 130, 246, 0.2);
            border-color: rgba(59, 130, 246, 0.3);
        }
    </style>
</head>
<body class="bg-darkBg text-slate-200 font-sans antialiased selection:bg-blue-500/30 overflow-x-hidden">

    <div class="fixed inset-0 bg-grid-pattern z-0 pointer-events-none opacity-40"></div>
    <div class="fixed top-[-10%] left-[-10%] w-[500px] h-[500px] bg-blue-600/20 rounded-full mix-blend-screen filter blur-[100px] animate-blob z-0 pointer-events-none"></div>
    <div class="fixed top-[20%] right-[-10%] w-[400px] h-[400px] bg-indigo-600/20 rounded-full mix-blend-screen filter blur-[100px] animate-blob animation-delay-2000 z-0 pointer-events-none"></div>

    <nav class="fixed w-full z-50 glass-nav">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-white text-darkBg rounded-lg flex items-center justify-center font-bold text-lg shadow-[0_0_15px_rgba(255,255,255,0.3)]">SH</div>
                <span class="font-bold text-xl tracking-tight text-white hidden sm:block">ADU Startup</span>
            </div>
            <div class="hidden md:flex gap-8 text-sm font-medium text-slate-400">
                <a href="#about" class="hover:text-white transition-colors">Loyiha haqida</a>
                <a href="#features" class="hover:text-white transition-colors">Imkoniyatlar</a>
                <a href="#ai" class="hover:text-white transition-colors">Sun'iy Intellekt</a>
            </div>
            <div>
                <a href="/login" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium rounded-full transition-all shadow-[0_0_20px_rgba(37,99,235,0.4)] hover:shadow-[0_0_30px_rgba(37,99,235,0.6)]">
                    Tizimga kirish
                </a>
            </div>
        </div>
    </nav>

    <section class="relative z-10 pt-48 pb-32 px-6 max-w-7xl mx-auto flex flex-col items-center text-center" id="about">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-blue-500/30 bg-blue-500/10 text-blue-400 text-xs font-semibold uppercase tracking-wider mb-8 animate-fade-in-up">
            <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
            Yopiq korporativ muhit
        </div>
        
        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-b from-white to-slate-400 mb-8 animate-fade-in-up text-glow" style="animation-delay: 0.1s;">
            Universitetning kelajak<br />ekotizimiga xush kelibsiz.
        </h1>
        
        <p class="text-lg md:text-xl text-slate-400 max-w-2xl mb-12 animate-fade-in-up" style="animation-delay: 0.2s;">
            Talabalar, tyutorlar va rahbarlar o'rtasida ko'prik vazifasini o'tovchi, sun'iy intellekt tomonidan himoyalangan ilk yopiq innovatsion startap maydoni.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up" style="animation-delay: 0.3s;">
            <a href="/login" class="px-8 py-3.5 bg-white text-darkBg font-semibold rounded-lg hover:bg-slate-200 transition-colors flex items-center justify-center gap-2">
                Hoziroq boshlash
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
            <a href="#features" class="px-8 py-3.5 bg-darkCard border border-darkBorder text-white font-semibold rounded-lg hover:bg-slate-800 transition-colors flex items-center justify-center">
                Batafsil ma'lumot
            </a>
        </div>
    </section>

    <section id="features" class="relative z-10 py-24 px-6 max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold mb-12 text-center text-white">Mukammal infratuzilma</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bento-card md:col-span-2 bg-darkCard border border-darkBorder rounded-3xl p-8 flex flex-col justify-between overflow-hidden relative" id="ai">
                <div class="z-10">
                    <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center mb-6 border border-blue-500/20">
                        <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-3">AI Senzura va Analitika</h3>
                    <p class="text-slate-400 max-w-md">Platformadagi barcha matnlar, g'oyalar va xabarlar Sun'iy Intellekt tomonidan filtrlanadi. Foydali muammolar tasdiqlanadi, sohalar avtomatik aniqlanadi.</p>
                </div>
                <div class="absolute right-0 bottom-0 w-64 h-64 bg-gradient-to-tl from-blue-600/20 to-transparent rounded-tl-[100px]"></div>
            </div>

            <div class="bento-card bg-darkCard border border-darkBorder rounded-3xl p-8 flex flex-col">
                <div class="w-12 h-12 bg-emerald-500/10 rounded-xl flex items-center justify-center mb-6 border border-emerald-500/20">
                    <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-3">Zirhli Eshik</h3>
                <p class="text-slate-400 text-sm">Tizim yopiq mavsumida faqat tyutorlar tomonidan beriladigan maxsus kodlar orqaligina jamoaga qo'shilish imkoniyati.</p>
            </div>

            <div class="bento-card bg-darkCard border border-darkBorder rounded-3xl p-8 flex flex-col">
                <div class="w-12 h-12 bg-purple-500/10 rounded-xl flex items-center justify-center mb-6 border border-purple-500/20">
                    <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-3">Soha Filtrlari</h3>
                <p class="text-slate-400 text-sm">Universitetga moslashtirilgan 15 xil mutaxassislik bo'yicha eng kuchli kadrlar va g'oyalarni izlash tizimi.</p>
            </div>

            <div class="bento-card md:col-span-2 bg-darkCard border border-darkBorder rounded-3xl p-8 flex items-center gap-8 relative overflow-hidden">
                <div class="z-10">
                    <h3 class="text-2xl font-bold text-white mb-3">Tizimli Analitika</h3>
                    <p class="text-slate-400 max-w-sm">Rahbariyat va tyutorlar uchun real vaqt rejimida loyihalar holati, MVP bosqichlari va muvaffaqiyatsizlik sabablarini ko'rsatuvchi Dashboard.</p>
                </div>
            </div>
        </div>
    </section>

    <footer class="relative z-10 border-t border-darkBorder bg-darkBg mt-12">
        <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-white text-darkBg rounded flex items-center justify-center font-bold text-sm">SH</div>
                <span class="font-bold text-slate-200">ADU Startup Hub</span>
            </div>
            <p class="text-sm text-slate-400 font-semibold tracking-wide uppercase">
                ILM Mizan me'morligida bunyod etildi.
            </p>
        </div>
    </footer>

    <button id="pwaInstallBtn" class="hidden fixed bottom-8 right-8 z-50 bg-indigo-600 hover:bg-indigo-500 text-white shadow-[0_0_20px_rgba(79,70,229,0.5)] px-5 py-3 rounded-2xl font-semibold items-center gap-3 transition-all transform hover:scale-105 animate-bounce-slow border border-indigo-400/30">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
        Ilovani yuklab olish
    </button>

    <script>
        let deferredPrompt;
        const installBtn = document.getElementById('pwaInstallBtn');

        // Brauzer ilova qilib o'rnatishga tayyor bo'lganda ishlaydi
        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            // Tugmani ko'rsatish
            installBtn.classList.remove('hidden');
            installBtn.classList.add('flex');
        });

        installBtn.addEventListener('click', async () => {
            if (deferredPrompt) {
                deferredPrompt.prompt();
                const { outcome } = await deferredPrompt.userChoice;
                if (outcome === 'accepted') {
                    installBtn.classList.add('hidden'); // O'rnatilsa tugma yo'qoladi
                }
                deferredPrompt = null;
            }
        });
    </script>
</body>
</html>
