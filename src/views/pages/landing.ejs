<!DOCTYPE html>
<html lang="uz" class="dark scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ADU Startup Hub - Kelajakni Quramiz</title>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0b1120">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        darkBg: '#0b1120',
                        darkCard: '#121928',
                        darkBorder: '#1e293b',
                    },
                    animation: {
                        'blob': 'blob 10s infinite alternate',
                    },
                    keyframes: {
                        blob: {
                            '0%': { transform: 'translate(0px, 0px) scale(1)' },
                            '100%': { transform: 'translate(20px, -40px) scale(1.05)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        .bg-grid-pattern {
            background-image: radial-gradient(rgba(148, 163, 184, 0.1) 1px, transparent 1px);
            background-size: 40px 40px;
        }
        .glass-nav {
            background: rgba(11, 17, 32, 0.6);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: all 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }
        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }
        .delay-100 { transition-delay: 100ms; }
        .delay-200 { transition-delay: 200ms; }
        .delay-300 { transition-delay: 300ms; }

        .bento-card {
            transition: transform 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease;
        }
        .bento-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 50px -12px rgba(59, 130, 246, 0.25);
            border-color: rgba(59, 130, 246, 0.4);
        }
    </style>
</head>
<body class="bg-darkBg text-slate-200 font-sans antialiased selection:bg-blue-500/30 overflow-x-hidden pb-24">

    <div class="fixed inset-0 bg-grid-pattern z-0 pointer-events-none opacity-40"></div>
    <div class="fixed top-[-20%] left-[-10%] w-[60vw] h-[60vw] bg-blue-600/10 rounded-full mix-blend-screen filter blur-[120px] animate-blob z-0 pointer-events-none"></div>

    <nav class="fixed w-full z-50 glass-nav transition-all duration-300" id="navbar">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <svg class="w-8 h-8 text-blue-500 drop-shadow-lg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2l.5-.5"/>
                    <path d="m12 15-3-3a22 22 0 0 1 3.8-11.2 2 2 0 0 1 3.2 0 22 22 0 0 1 3.8 11.2l-3 3"/>
                    <path d="m9 12 3 3"/>
                </svg>
                <span class="font-bold text-xl tracking-tight text-white hidden sm:block">ADU Startup</span>
            </div>
            
            <div class="hidden md:flex gap-10 text-sm font-medium text-slate-400">
                <a href="#about" class="hover:text-white transition-colors duration-300">Loyiha haqida</a>
                <a href="#features" class="hover:text-white transition-colors duration-300">Imkoniyatlar</a>
            </div>
            <div>
                <a href="/login" class="px-6 py-2.5 bg-white text-darkBg text-sm font-bold rounded-full transition-all hover:scale-105 shadow-[0_0_20px_rgba(255,255,255,0.2)]">
                    Tizimga kirish
                </a>
            </div>
        </div>
    </nav>

    <section class="relative z-10 pt-40 md:pt-56 pb-24 md:pb-40 px-6 max-w-7xl mx-auto flex flex-col items-center text-center" id="about">
        <div class="reveal inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-blue-500/20 bg-blue-500/10 text-blue-400 text-xs font-semibold uppercase tracking-widest mb-8 backdrop-blur-md">
            <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span>
            Korporativ Ekotizim
        </div>
        
        <h1 class="reveal delay-100 text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tighter text-transparent bg-clip-text bg-gradient-to-b from-white via-slate-200 to-slate-500 mb-8 pb-2">
            Kelajakni idrok eting.
        </h1>
        
        <p class="reveal delay-200 text-lg md:text-2xl text-slate-400 max-w-3xl mb-12 font-light leading-relaxed">
            Talabalar, tyutorlar va rahbarlar uchun mo'ljallangan yagona yopiq platforma. Sun'iy intellekt tomonidan boshqariladigan innovatsiyalar markazi.
        </p>
        
        <div class="reveal delay-300 flex flex-col sm:flex-row gap-5 w-full sm:w-auto">
            <a href="/login" class="px-8 py-4 bg-blue-600 text-white font-semibold rounded-2xl hover:bg-blue-500 transition-all shadow-[0_0_30px_rgba(37,99,235,0.4)] flex items-center justify-center gap-3 group">
                Hozir boshlash
                <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
            <a href="#features" class="px-8 py-4 bg-transparent border border-darkBorder text-white font-semibold rounded-2xl hover:bg-white/5 transition-colors flex items-center justify-center">
                Imkoniyatlarni ko'rish
            </a>
        </div>
    </section>

    <section id="features" class="relative z-10 py-24 md:py-32 px-6 max-w-7xl mx-auto">
        <h2 class="reveal text-3xl md:text-5xl font-bold mb-16 text-center text-white tracking-tight">Mukammallik har bir detalda.</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="reveal bento-card md:col-span-2 bg-darkCard border border-darkBorder/80 rounded-[32px] p-8 md:p-12 flex flex-col justify-between overflow-hidden relative group">
                <div class="z-10 relative">
                    <div class="w-14 h-14 bg-blue-500/10 rounded-2xl flex items-center justify-center mb-8 border border-blue-500/20 backdrop-blur-md">
                        <svg class="w-7 h-7 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                    </div>
                    <h3 class="text-2xl md:text-3xl font-bold text-white mb-4 tracking-tight">Intellektual Senzura</h3>
                    <p class="text-slate-400 text-lg md:max-w-md font-light leading-relaxed">
                        Platformadagi har bir g'oya, xabar va loyiha Sun'iy Intellekt filtridan o'tadi. Yomon so'zlar bloklanadi, g'oyalar tahlil qilinadi.
                    </p>
                </div>
                <div class="absolute -right-20 -bottom-20 w-80 h-80 bg-blue-600/20 rounded-full blur-[80px] group-hover:bg-blue-600/30 transition-colors duration-700"></div>
            </div>

            <div class="reveal delay-100 bento-card bg-darkCard border border-darkBorder/80 rounded-[32px] p-8 md:p-10 flex flex-col relative overflow-hidden group">
                <div class="w-12 h-12 bg-emerald-500/10 rounded-2xl flex items-center justify-center mb-6 border border-emerald-500/20 z-10">
                    <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-3 z-10">Zirhli Eshik</h3>
                <p class="text-slate-400 font-light z-10">Tizim yopiq mavsumida faqat tyutorlar tomonidan beriladigan vaqtinchalik kodlar bilangina kirish mumkin.</p>
                <div class="absolute -right-10 -top-10 w-40 h-40 bg-emerald-600/10 rounded-full blur-[40px] group-hover:bg-emerald-600/20 transition-colors"></div>
            </div>

            <div class="reveal delay-200 bento-card bg-darkCard border border-darkBorder/80 rounded-[32px] p-8 md:p-10 flex flex-col relative overflow-hidden group">
                <div class="w-12 h-12 bg-purple-500/10 rounded-2xl flex items-center justify-center mb-6 border border-purple-500/20 z-10">
                    <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-3 z-10">15 xil Mutaxassislik</h3>
                <p class="text-slate-400 font-light z-10">Faqatgina universitetga va biznesga aloqador eng kerakli sohalar boyicha filtrlash imkoniyati.</p>
                <div class="absolute -left-10 -bottom-10 w-40 h-40 bg-purple-600/10 rounded-full blur-[40px] group-hover:bg-purple-600/20 transition-colors"></div>
            </div>

            <div class="reveal delay-300 bento-card md:col-span-2 bg-darkCard border border-darkBorder/80 rounded-[32px] p-8 md:p-10 flex items-center relative overflow-hidden group">
                <div class="z-10">
                    <h3 class="text-2xl font-bold text-white mb-3">Chuqur Analitika</h3>
                    <p class="text-slate-400 font-light max-w-lg">Rahbariyat va tyutorlar uchun real vaqt rejimida loyihalar holati, taraqqiyoti va rad etilish sabablarini tahlil qiluvchi mukammal Dashboard paneli.</p>
                </div>
            </div>
        </div>
    </section>

    <footer class="relative z-10 border-t border-white/5 bg-darkBg/50 backdrop-blur-xl mt-10">
        <div class="max-w-7xl mx-auto px-6 py-10 flex flex-col md:flex-row justify-between items-center gap-6 text-center md:text-left">
            <div class="flex items-center gap-3">
                <svg class="w-6 h-6 text-slate-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2l.5-.5"/>
                    <path d="m12 15-3-3a22 22 0 0 1 3.8-11.2 2 2 0 0 1 3.2 0 22 22 0 0 1 3.8 11.2l-3 3"/>
                    <path d="m9 12 3 3"/>
                </svg>
                <span class="font-bold text-slate-300 tracking-wide">ADU Startup Hub</span>
            </div>
            <p class="text-[13px] text-slate-500 font-semibold tracking-widest uppercase">
                ILM Mizan me'morligida bunyod etildi.
            </p>
        </div>
    </footer>

    <button id="pwaInstallBtn" onclick="installPWA()" class="hidden fixed bottom-6 right-6 z-50 bg-white/10 hover:bg-white/20 backdrop-blur-md border border-white/20 text-white shadow-2xl px-5 py-3 rounded-full font-medium items-center gap-3 transition-all transform hover:scale-105 group">
        <svg class="w-5 h-5 text-blue-400 group-hover:animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
        <span class="hidden sm:block">Ilovani yuklash</span>
        <span class="sm:hidden">Yuklash</span>
    </button>

    <script>
        // 1. Scroll Animatsiyalar
        document.addEventListener("DOMContentLoaded", () => {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });

            document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
        });

        // 2. HAQIQIY PWA ENGINE (Service Worker ro'yxatdan o'tkazish)
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .then(reg => console.log('PWA Dvigateli faollashdi!'))
                    .catch(err => console.log('PWA Xato:', err));
            });
        }

        let deferredPrompt;
        const installBtn = document.getElementById('pwaInstallBtn');
        
        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            installBtn.classList.remove('hidden');
            installBtn.classList.add('flex');
        });

        function installPWA() {
            if (deferredPrompt) {
                deferredPrompt.prompt();
                deferredPrompt.userChoice.then((choiceResult) => {
                    if (choiceResult.outcome === 'accepted') {
                        installBtn.classList.add('hidden');
                    }
                    deferredPrompt = null;
                });
            } else {
                alert("Ilovani o'rnatish uchun brauzeringiz menyusidan 'Add to Home Screen' (Ekranga qo'shish) tugmasini bosing.");
            }
        }
    </script>
</body>
</html>
