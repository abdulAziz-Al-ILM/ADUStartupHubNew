<!DOCTYPE html>
<html lang="uz" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ADU Startup Hub - Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        darkBg: '#0b1120',
                        darkCard: '#151e32',
                        darkBorder: '#1e293b',
                        darkTextMain: '#e2e8f0',
                        darkTextSub: '#94a3b8'
                    }
                }
            }
        }
    </script>
    <style>
        .bg-grid-pattern {
            background-image: radial-gradient(rgba(148, 163, 184, 0.08) 1px, transparent 1px);
            background-size: 24px 24px;
        }
        /* Scrollbar dizayni */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #334155; }
    </style>
</head>
<body class="bg-darkBg text-darkTextMain font-sans antialiased h-screen flex overflow-hidden selection:bg-blue-500/30">

    <aside class="w-64 bg-darkCard border-r border-darkBorder flex flex-col justify-between hidden md:flex shrink-0 z-20 shadow-2xl">
        <div>
            <div class="h-20 flex items-center gap-3 px-6 border-b border-darkBorder">
                <div class="w-8 h-8 bg-blue-600 text-white rounded flex items-center justify-center font-bold text-sm shadow-[0_0_10px_rgba(37,99,235,0.5)]">SH</div>
                <span class="font-bold text-lg tracking-tight">Startup Hub</span>
            </div>
            
            <nav class="p-4 space-y-2">
                <button onclick="switchTab('main-tab')" id="nav-main-tab" class="nav-btn w-full flex items-center gap-3 px-4 py-3 bg-blue-600/10 text-blue-400 rounded-xl transition-colors font-medium text-sm border border-blue-500/20">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                    Asosiy Ko'rsatkichlar
                </button>
                <button onclick="switchTab('projects-tab')" id="nav-projects-tab" class="nav-btn w-full flex items-center gap-3 px-4 py-3 text-darkTextSub hover:bg-darkBg hover:text-darkTextMain rounded-xl transition-colors font-medium text-sm">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                    Startap Loyihalar
                </button>
                <button onclick="switchTab('news-tab')" id="nav-news-tab" class="nav-btn w-full flex items-center gap-3 px-4 py-3 text-emerald-400 hover:bg-emerald-500/10 rounded-xl transition-colors font-medium text-sm border border-transparent">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path></svg>
                    ILM Mizan Xabarlari
                </button>
            </nav>
        </div>

        <div class="p-4 border-t border-darkBorder">
            <div class="flex items-center gap-3 mb-4 p-2 rounded-xl bg-darkBg border border-darkBorder cursor-pointer hover:border-gray-600 transition-colors">
                <div class="w-10 h-10 bg-gradient-to-tr from-blue-500 to-purple-500 rounded-full flex items-center justify-center text-xl shadow-inner">
                    👨‍💻 </div>
                <div class="overflow-hidden">
                    <p class="text-sm font-bold truncate" id="userNameDisplay">Yuklanmoqda...</p>
                    <p class="text-xs text-darkTextSub truncate" id="userRoleDisplay">Talaba</p>
                </div>
            </div>
            <button onclick="logout()" class="w-full py-2 text-xs font-semibold text-red-400 hover:text-red-300 transition-colors">
                Tizimdan chiqish
            </button>
            <p class="text-[10px] text-center text-darkTextSub mt-4 tracking-wider opacity-60">ILM MIZAN ME'MORLIGIDA BUNYOD ETILDI.</p>
        </div>
    </aside>

    <main class="flex-1 flex flex-col relative bg-grid-pattern">
        
        <header class="h-20 flex items-center justify-between px-8 border-b border-darkBorder bg-darkBg/80 backdrop-blur-md z-10">
            <h2 id="pageTitle" class="text-xl font-bold tracking-tight">Dashboard</h2>
            
            <button id="pwaInstallBtn" class="hidden px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg text-sm font-semibold transition-all shadow-[0_0_15px_rgba(79,70,229,0.4)] flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                O'rnatish
            </button>
        </header>

        <div class="flex-1 overflow-y-auto p-8 relative z-0">

            <div id="main-tab" class="tab-content animate-fade-in-up">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                    <div class="bg-darkCard border border-darkBorder p-6 rounded-2xl flex flex-col justify-center">
                        <span class="text-darkTextSub text-sm font-medium mb-1">Jami loyihalar</span>
                        <span class="text-4xl font-bold text-white">0</span>
                    </div>
                    <div class="bg-darkCard border border-darkBorder p-6 rounded-2xl flex flex-col justify-center">
                        <span class="text-darkTextSub text-sm font-medium mb-1">Muvaffaqiyatli chiqqan</span>
                        <span class="text-4xl font-bold text-emerald-400">0</span>
                    </div>
                    <div class="bg-darkCard border border-darkBorder p-6 rounded-2xl flex flex-col justify-center">
                        <span class="text-darkTextSub text-sm font-medium mb-1">Platformadagi mutaxassislar</span>
                        <span class="text-4xl font-bold text-blue-400">0</span>
                    </div>
                </div>
                </div>

            <div id="projects-tab" class="tab-content hidden animate-fade-in-up">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-2xl font-bold">Startap Loyihalar</h3>
                    <button class="px-4 py-2 bg-white text-darkBg font-semibold rounded-lg text-sm hover:bg-gray-200 transition-colors">
                        + Yangi loyiha
                    </button>
                </div>
                <div class="text-center py-20 border border-dashed border-darkBorder rounded-2xl text-darkTextSub">
                    Hozircha hech qanday loyiha yo'q. Birinchilardan bo'ling!
                </div>
            </div>

            <div id="news-tab" class="tab-content hidden animate-fade-in-up">
                <div class="mb-8 border-b border-darkBorder pb-4">
                    <h3 class="text-2xl font-bold text-emerald-400 flex items-center gap-2">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path></svg>
                        E'lonlar va Yangiliklar
                    </h3>
                    <p class="text-darkTextSub text-sm mt-1">Rahbariyat va ILM Mizan markazi tomonidan yuborilgan barcha rasmiy xabarlar.</p>
                </div>

                <div class="flex flex-col gap-4">
                    <div class="bg-darkCard border border-darkBorder rounded-2xl p-6 relative overflow-hidden group">
                        <div class="absolute top-0 left-0 w-1 h-full bg-emerald-500"></div>
                        <div class="flex justify-between items-start mb-4">
                            <span class="px-2.5 py-1 bg-emerald-500/10 text-emerald-400 text-xs font-bold rounded uppercase tracking-wider">Muxim e'lon</span>
                            <span class="text-xs text-darkTextSub">05 Aprel, 2026</span>
                        </div>
                        <h4 class="text-lg font-bold text-white mb-2">Platforma rasman o'z ishini boshladi!</h4>
                        <p class="text-darkTextSub text-sm leading-relaxed">
                            Hurmatli talabalar, bugundan e'tiboran ADU Startup Hub yopiq ekotizimi to'liq ishga tushirildi. O'z g'oyalaringizni kiritishingiz va AI yordamida jamoa yig'ishingiz mumkin.
                        </p>
                    </div>

                    <div class="bg-darkCard border border-darkBorder rounded-2xl p-6 relative overflow-hidden">
                        <div class="absolute top-0 left-0 w-1 h-full bg-blue-500"></div>
                        <div class="flex justify-between items-start mb-4">
                            <span class="px-2.5 py-1 bg-blue-500/10 text-blue-400 text-xs font-bold rounded uppercase tracking-wider">Tizim yangilanishi</span>
                            <span class="text-xs text-darkTextSub">01 Aprel, 2026</span>
                        </div>
                        <h4 class="text-lg font-bold text-white mb-2">Sun'iy Intellekt senzurasi faollashdi</h4>
                        <p class="text-darkTextSub text-sm leading-relaxed">
                            Barcha foydalanuvchilar diqqatiga: xabarlar, loyiha tavsiflari va muammolar bazasi endilikda AI tomonidan to'liq nazorat qilinadi.
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <script>
        // 1. Tizimga kirganini tekshirish
        const token = localStorage.getItem('hub_token');
        if (!token) {
            window.location.href = '/login';
        }

        // 2. Foydalanuvchi ma'lumotlarini API dan yuklab olish (Kelajakda ulaymiz)
        // fetch('/api/users/me', ...)

        // 3. Tablarni (Sahifalarni) almashtirish logikasi
        function switchTab(tabId) {
            // Hamma tablarni yashirish
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.add('hidden');
            });
            // Hamma menyulardan aktivlik rangini olish
            document.querySelectorAll('.nav-btn').forEach(btn => {
                btn.className = "nav-btn w-full flex items-center gap-3 px-4 py-3 text-darkTextSub hover:bg-darkBg hover:text-darkTextMain rounded-xl transition-colors font-medium text-sm border border-transparent";
            });

            // Tanlangan tabni ko'rsatish
            document.getElementById(tabId).classList.remove('hidden');
            
            // Tanlangan menyuga rang berish
            const activeBtn = document.getElementById('nav-' + tabId);
            if(tabId === 'news-tab') {
                activeBtn.className = "nav-btn w-full flex items-center gap-3 px-4 py-3 text-emerald-400 bg-emerald-500/10 rounded-xl transition-colors font-medium text-sm border border-emerald-500/20";
                document.getElementById('pageTitle').textContent = "ILM Mizan Xabarlari";
            } else if(tabId === 'main-tab') {
                activeBtn.className = "nav-btn w-full flex items-center gap-3 px-4 py-3 bg-blue-600/10 text-blue-400 rounded-xl transition-colors font-medium text-sm border border-blue-500/20";
                document.getElementById('pageTitle').textContent = "Dashboard";
            } else {
                activeBtn.className = "nav-btn w-full flex items-center gap-3 px-4 py-3 bg-blue-600/10 text-blue-400 rounded-xl transition-colors font-medium text-sm border border-blue-500/20";
                document.getElementById('pageTitle').textContent = "Startap Loyihalar";
            }
        }

        // 4. Chiqish
        function logout() {
            localStorage.removeItem('hub_token');
            window.location.href = '/login';
        }

        // 5. PWA (Ilova) o'rnatish logikasi
        let deferredPrompt;
        const installBtn = document.getElementById('pwaInstallBtn');

        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            installBtn.classList.remove('hidden');
        });

        installBtn.addEventListener('click', async () => {
            if (deferredPrompt) {
                deferredPrompt.prompt();
                const { outcome } = await deferredPrompt.userChoice;
                if (outcome === 'accepted') {
                    installBtn.classList.add('hidden');
                }
                deferredPrompt = null;
            }
        });
    </script>
</body>
</html>
