<!DOCTYPE html>
<html lang="uz" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ADU Startup Hub - Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        darkBg: '#0b1120',
                        darkCard: '#121928',
                        darkBorder: '#1e293b',
                        darkTextMain: '#e2e8f0',
                        darkTextSub: '#94a3b8'
                    }
                }
            }
        }
    </script>
    <style>
        .bg-turon-pattern {
            background-color: #0b1120;
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cpath d='M30 0l15 15-15 15L15 15 30 0zm0 30l15 15-15 15-15-15 15-15zM0 30l15-15v30L0 30zm60 0l-15-15v30l15-15z' stroke='%233b82f6' stroke-width='1' stroke-opacity='0.03'/%3E%3C/g%3E%3C/svg%3E");
        }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #334155; }
        
        /* AURA Kartocha Effektlari */
        .aura-card {
            transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.4s ease;
        }
        .aura-card:hover {
            transform: translateY(-4px) scale(1.01);
            z-index: 10;
        }
        .bg-text-watermark {
            font-size: 5rem;
            font-weight: 900;
            line-height: 1;
            color: rgba(255, 255, 255, 0.03);
            position: absolute;
            right: -1rem;
            bottom: -1rem;
            user-select: none;
            pointer-events: none;
        }
    </style>
</head>
<body class="bg-turon-pattern text-darkTextMain font-sans antialiased h-screen flex overflow-hidden selection:bg-blue-500/30">

    <div id="sidebarOverlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-30 hidden md:hidden transition-opacity opacity-0"></div>

    <aside id="sidebar" class="fixed inset-y-0 left-0 w-72 bg-darkCard/90 backdrop-blur-xl border-r border-darkBorder flex flex-col justify-between z-40 transform -translate-x-full md:relative md:translate-x-0 transition-transform duration-300 shadow-2xl">
        <div class="overflow-y-auto h-full">
            <div class="h-20 flex items-center justify-between px-6 border-b border-darkBorder bg-darkBg/50 sticky top-0 z-10">
                <div class="flex items-center gap-3">
                    <svg class="w-8 h-8 text-blue-500 drop-shadow-md" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                        <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                        <line x1="12" y1="22.08" x2="12" y2="12"></line>
                    </svg>
                    <span class="font-bold text-lg tracking-tight">Startup Hub</span>
                </div>
                <button id="closeMenuBtn" class="md:hidden text-darkTextSub hover:text-white">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            
            <nav class="p-4 space-y-1.5 mt-2">
                <button onclick="switchTab('main-tab')" id="nav-main-tab" class="nav-btn w-full flex items-center gap-3 px-4 py-3.5 bg-blue-600/10 text-blue-400 rounded-xl transition-all font-medium text-sm border border-blue-500/20">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                    Asosiy Ko'rsatkichlar
                </button>
                <button onclick="switchTab('projects-tab')" id="nav-projects-tab" class="nav-btn w-full flex items-center gap-3 px-4 py-3.5 text-darkTextSub hover:bg-white/5 hover:text-darkTextMain rounded-xl transition-all font-medium text-sm border border-transparent">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                    Startap Loyihalar
                </button>
                <button onclick="switchTab('specialists-tab')" id="nav-specialists-tab" class="nav-btn w-full flex items-center gap-3 px-4 py-3.5 text-darkTextSub hover:bg-white/5 hover:text-darkTextMain rounded-xl transition-all font-medium text-sm border border-transparent">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                    Mutaxassislar Bazas
                </button>
                <button onclick="switchTab('problems-tab')" id="nav-problems-tab" class="nav-btn w-full flex items-center gap-3 px-4 py-3.5 text-darkTextSub hover:bg-white/5 hover:text-darkTextMain rounded-xl transition-all font-medium text-sm border border-transparent">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Muammolar Bazas
                </button>
                <div class="h-px bg-darkBorder my-2 mx-4"></div>
                <button onclick="switchTab('manual-tab')" id="nav-manual-tab" class="nav-btn w-full flex items-center gap-3 px-4 py-3.5 text-orange-400 hover:bg-orange-500/10 rounded-xl transition-all font-medium text-sm border border-transparent">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                    Tizim Qo'llanmasi
                </button>
                <button onclick="switchTab('news-tab')" id="nav-news-tab" class="nav-btn w-full flex items-center gap-3 px-4 py-3.5 text-emerald-400 hover:bg-emerald-500/10 rounded-xl transition-all font-medium text-sm border border-transparent">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path></svg>
                    ILM Mizan Xabarlari
                </button>
            </nav>
        </div>

        <div class="p-4 border-t border-darkBorder bg-darkBg/50 backdrop-blur-md shrink-0">
            <div class="flex items-center gap-3 mb-4 p-2.5 rounded-xl bg-darkCard border border-darkBorder hover:border-gray-600 transition-colors shadow-sm cursor-pointer" onclick="switchTab('profile-tab')">
                <div class="w-10 h-10 bg-gradient-to-tr from-blue-600 to-purple-600 rounded-full flex items-center justify-center text-xl shadow-inner border border-white/10" id="userSticker">
                    👨‍💻
                </div>
                <div class="overflow-hidden flex-1">
                    <p class="text-sm font-bold text-white truncate" id="userNameDisplay">Yuklanmoqda...</p>
                    <p class="text-[11px] text-blue-400 font-bold truncate uppercase tracking-wider" id="userRoleDisplay">...</p>
                </div>
                <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </div>
            <button onclick="logout()" class="w-full py-2.5 bg-red-500/10 text-xs font-bold text-red-400 hover:bg-red-500/20 rounded-lg transition-colors border border-red-500/20">
                TIZIMDAN CHIQISH
            </button>
            <p class="text-[10px] text-center text-darkTextSub mt-4 font-bold tracking-widest uppercase opacity-40">ILM MIZAN ME'MORLIGIDA BUNYOD ETILDI.</p>
        </div>
    </aside>

    <main class="flex-1 flex flex-col relative bg-transparent h-screen overflow-hidden">
        
        <header class="h-20 flex items-center justify-between px-6 md:px-10 border-b border-darkBorder bg-darkBg/80 backdrop-blur-xl z-20 shrink-0">
            <div class="flex items-center gap-4">
                <button id="openMenuBtn" class="md:hidden text-white hover:text-blue-400 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </button>
                <h2 id="pageTitle" class="text-2xl font-extrabold tracking-tight text-white">Asosiy Ko'rsatkichlar</h2>
            </div>
            
            <button id="pwaInstallBtn" onclick="installPWA()" class="hidden px-5 py-2.5 bg-white text-darkBg hover:bg-gray-200 rounded-xl text-sm font-bold transition-all shadow-[0_0_20px_rgba(255,255,255,0.2)] hover:scale-105 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                <span class="hidden md:block">Ilova qilib o'rnatish</span>
            </button>
        </header>

        <div class="flex-1 overflow-y-auto p-6 md:p-10 relative z-0">

            <div id="main-tab" class="tab-content transition-all duration-500 opacity-100 translate-y-0">
                
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 mb-8">
                    <div class="bg-darkCard/80 backdrop-blur-md border border-darkBorder p-6 rounded-[24px] flex flex-col justify-center shadow-lg relative overflow-hidden">
                        <span class="text-darkTextSub text-xs font-bold uppercase tracking-widest mb-1 relative z-10">Tizimdagi Mutaxassislar</span>
                        <span class="text-4xl font-black text-white relative z-10" id="statSpecialists">-</span>
                    </div>
                    <div class="bg-darkCard/80 backdrop-blur-md border border-darkBorder p-6 rounded-[24px] flex flex-col justify-center shadow-lg relative overflow-hidden">
                        <div class="absolute right-0 top-0 w-24 h-24 bg-emerald-500/20 rounded-full blur-2xl"></div>
                        <span class="text-darkTextSub text-xs font-bold uppercase tracking-widest mb-1 relative z-10">Bozordagi Startaplar</span>
                        <span class="text-4xl font-black text-emerald-400 relative z-10" id="statInMarket">-</span>
                    </div>
                    <div class="bg-darkCard/80 backdrop-blur-md border border-darkBorder p-6 rounded-[24px] flex flex-col justify-center shadow-lg relative overflow-hidden">
                        <div class="absolute right-0 top-0 w-24 h-24 bg-purple-500/20 rounded-full blur-2xl"></div>
                        <span class="text-darkTextSub text-xs font-bold uppercase tracking-widest mb-1 relative z-10">Sarmoya Kutayotgan (MVP)</span>
                        <span class="text-4xl font-black text-purple-400 relative z-10" id="statMvp">-</span>
                    </div>
                    <div class="bg-darkCard/80 backdrop-blur-md border border-darkBorder p-6 rounded-[24px] flex flex-col justify-center shadow-lg relative overflow-hidden">
                        <div class="absolute right-0 top-0 w-24 h-24 bg-orange-500/20 rounded-full blur-2xl"></div>
                        <span class="text-darkTextSub text-xs font-bold uppercase tracking-widest mb-1 relative z-10">Jamoa Yig'ayotganlar</span>
                        <span class="text-4xl font-black text-orange-400 relative z-10" id="statTeam">-</span>
                    </div>
                </div>

                <div id="adminSection" class="hidden mb-10">
                    <h3 class="text-xl font-extrabold text-red-400 mb-4 flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                        AI Sabablari: Rad etilgan va Tugatilgan Loyihalar
                    </h3>
                    <div class="bg-darkCard border border-darkBorder rounded-[24px] p-6 text-sm text-slate-400 max-h-80 overflow-y-auto shadow-inner" id="canceledProjectsBox">
                        Yuklanmoqda...
                    </div>
                </div>

                <div id="tutorSection" class="hidden mb-10">
                    <h3 class="text-xl font-extrabold text-white mb-4">Mening Xodimlarim (Talabalar)</h3>
                    <div class="bg-darkCard/80 backdrop-blur-md border border-darkBorder rounded-[24px] p-8 flex items-center justify-between shadow-lg">
                        <div>
                            <p class="text-slate-400 font-medium">Sizning kodingiz bilan ro'yxatdan o'tganlar</p>
                            <p class="text-sm mt-1 text-emerald-400">Ular yaratgan loyihalar avtomatik nazoratingizda bo'ladi.</p>
                        </div>
                        <div class="text-5xl font-black text-white" id="tutorStudentCount">0</div>
                    </div>
                </div>

                <div id="studentSection" class="hidden mb-10">
                    <h3 class="text-xl font-extrabold text-white mb-4">Kunlik Interaktiv Limitlar</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="bg-darkCard/80 border border-darkBorder p-6 rounded-[24px] flex justify-between items-center shadow-lg">
                            <div>
                                <p class="text-slate-400 text-sm font-semibold">Tahrirlash / Saqlash</p>
                                <p class="text-3xl font-black text-white mt-1" id="profileLimitDisplay">2 / 2</p>
                            </div>
                            <div class="w-14 h-14 bg-blue-500/10 rounded-2xl flex items-center justify-center text-blue-400 border border-blue-500/20">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                            </div>
                        </div>
                        <div class="bg-darkCard/80 border border-darkBorder p-6 rounded-[24px] flex justify-between items-center shadow-lg">
                            <div>
                                <p class="text-slate-400 text-sm font-semibold">Yangi muammo qo'shish</p>
                                <p class="text-3xl font-black text-white mt-1" id="ideaLimitDisplay">2 / 2</p>
                            </div>
                            <div class="w-14 h-14 bg-emerald-500/10 rounded-2xl flex items-center justify-center text-emerald-400 border border-emerald-500/20">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="projects-tab" class="tab-content hidden opacity-0 translate-y-4 transition-all duration-500">
                
                <div class="flex flex-col md:flex-row gap-4 mb-8">
                    <div class="flex-1 relative">
                        <svg class="w-5 h-5 absolute left-4 top-3.5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        <input type="text" id="projectSearch" placeholder="Loyiha nomi yoki kalit so'z..." class="w-full bg-darkCard/80 backdrop-blur-md border border-darkBorder rounded-2xl pl-11 pr-4 py-3.5 text-white placeholder:text-slate-500 outline-none focus:border-blue-500 transition-colors shadow-lg">
                    </div>
                    <select id="projectCategory" class="bg-darkCard/80 backdrop-blur-md border border-darkBorder rounded-2xl px-4 py-3.5 text-white outline-none focus:border-blue-500 transition-colors shadow-lg appearance-none cursor-pointer">
                        <option value="">Barcha sohalar</option>
                        <option value="IT_ENGINEER">IT Muhandislik</option>
                        <option value="MARKETOLOG">Marketing</option>
                        <option value="ECONOMIST">Iqtisodiyot</option>
                        </select>
                    <select id="projectStatus" class="bg-darkCard/80 backdrop-blur-md border border-darkBorder rounded-2xl px-4 py-3.5 text-white outline-none focus:border-blue-500 transition-colors shadow-lg appearance-none cursor-pointer">
                        <option value="">Barcha holatlar</option>
                        <option value="TEAM_BUILDING">Jamoa yig'moqda</option>
                        <option value="NEED_INVESTMENT">Sarmoya izlamoqda</option>
                        <option value="IN_MARKET">Bozorda</option>
                    </select>
                    <button id="addProjectBtn" class="hidden px-6 py-3.5 bg-white text-darkBg font-extrabold rounded-2xl hover:bg-gray-200 transition-all shadow-[0_0_20px_rgba(255,255,255,0.2)] flex items-center justify-center gap-2 whitespace-nowrap">
                        + Yangi Startap
                    </button>
                </div>

                <div class="flex flex-col gap-6 pb-20" id="projectsList">
                    <div class="aura-card relative w-full rounded-[28px] overflow-hidden bg-gradient-to-r from-[#0b1120] to-[#0f172a] border border-[#1e293b] p-8 md:p-10 flex flex-col md:flex-row justify-between cursor-pointer group">
                        <div class="absolute -left-20 -top-20 w-64 h-64 bg-blue-600/20 rounded-full blur-[80px] pointer-events-none group-hover:bg-blue-600/30 transition-colors"></div>
                        <div class="bg-text-watermark">INTELLIGENCE</div>
                        
                        <div class="relative z-10 flex-1">
                            <div class="flex items-center gap-3 mb-4">
                                <span class="px-3 py-1 bg-blue-500/20 text-blue-400 text-xs font-bold rounded-lg uppercase tracking-widest border border-blue-500/30 backdrop-blur-md">IT_ENGINEER</span>
                                <span class="px-3 py-1 bg-orange-500/20 text-orange-400 text-xs font-bold rounded-lg uppercase tracking-widest border border-orange-500/30 backdrop-blur-md">MVP_PREPARATION</span>
                            </div>
                            <h3 class="text-3xl md:text-4xl font-extrabold text-white mb-2 tracking-tight">Tech Nova AI</h3>
                            <p class="text-slate-400 text-base md:text-lg font-medium max-w-2xl">Universitet ta'limini sun'iy intellekt yordamida shaxsiylashtiruvchi ekotizim platformasi.</p>
                            <div class="mt-6 flex items-center gap-4 text-sm font-semibold text-slate-500">
                                <div class="flex items-center gap-1.5"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> 6 oy muddat</div>
                                <div class="flex items-center gap-1.5"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg> 4 ishtirokchi</div>
                            </div>
                        </div>
                        
                        <div class="relative z-10 hidden md:flex items-center justify-end w-48">
                            <div class="w-20 h-20 bg-white/5 border border-white/10 rounded-full flex items-center justify-center backdrop-blur-xl group-hover:bg-blue-500 group-hover:border-blue-400 group-hover:shadow-[0_0_30px_rgba(59,130,246,0.6)] transition-all duration-300">
                                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                            </div>
                        </div>
                    </div>

                    <div class="aura-card relative w-full rounded-[28px] overflow-hidden bg-gradient-to-r from-[#0b1120] to-[#0f172a] border border-[#1e293b] p-8 md:p-10 flex flex-col md:flex-row justify-between cursor-pointer group">
                        <div class="absolute -left-20 -top-20 w-64 h-64 bg-emerald-600/20 rounded-full blur-[80px] pointer-events-none group-hover:bg-emerald-600/30 transition-colors"></div>
                        <div class="bg-text-watermark">SUSTAINABILITY</div>
                        
                        <div class="relative z-10 flex-1">
                            <div class="flex items-center gap-3 mb-4">
                                <span class="px-3 py-1 bg-emerald-500/20 text-emerald-400 text-xs font-bold rounded-lg uppercase tracking-widest border border-emerald-500/30 backdrop-blur-md">ECOLOGIST</span>
                                <span class="px-3 py-1 bg-purple-500/20 text-purple-400 text-xs font-bold rounded-lg uppercase tracking-widest border border-purple-500/30 backdrop-blur-md">IN_MARKET</span>
                            </div>
                            <h3 class="text-3xl md:text-4xl font-extrabold text-white mb-2 tracking-tight">AquaGuard</h3>
                            <p class="text-slate-400 text-base md:text-lg font-medium max-w-2xl">Orol dengizi atrofidagi hududlarda suv resurslarini tejamkor boshqarish aqlli tizimi.</p>
                        </div>
                        <div class="relative z-10 hidden md:flex items-center justify-end w-48">
                            <div class="w-20 h-20 bg-white/5 border border-white/10 rounded-full flex items-center justify-center backdrop-blur-xl group-hover:bg-emerald-500 group-hover:border-emerald-400 group-hover:shadow-[0_0_30px_rgba(16,185,129,0.6)] transition-all duration-300">
                                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="specialists-tab" class="tab-content hidden opacity-0 translate-y-4 transition-all duration-500">
                <h3 class="text-3xl font-bold text-white mb-6">Mutaxassislar Bazasi</h3>
                <p class="text-slate-400">O'z sohasining mutaxassislari, ularning ochiq rezyumelari shu yerda ko'rinadi.</p>
            </div>
            
            <div id="problems-tab" class="tab-content hidden opacity-0 translate-y-4 transition-all duration-500">
                <h3 class="text-3xl font-bold text-white mb-6">Muammolar Bazasi</h3>
                <p class="text-slate-400">AI tomonidan tasdiqlangan jamiyat muammolari va ularga yechim g'oyalari.</p>
            </div>

            <div id="manual-tab" class="tab-content hidden opacity-0 translate-y-4 transition-all duration-500">
                <h3 class="text-3xl font-bold text-orange-400 mb-6">Tizim Qo'llanmasi</h3>
                <p class="text-slate-400">Bu yerda startap yaratish va tizimdan foydalanish bo'yicha Admin kiritgan xavfsiz havolalar turadi.</p>
            </div>

            <div id="news-tab" class="tab-content hidden opacity-0 translate-y-4 transition-all duration-500">
                <h3 class="text-3xl font-bold text-emerald-400 mb-6">ILM Mizan Xabarlari</h3>
                <p class="text-slate-400">Rahbariyatning rasmiy xabarlari.</p>
            </div>

        </div>
    </main>

    <script>
        // 1. MOBIL MENYU LOGIKASI
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');

        function toggleMenu() {
            const isClosed = sidebar.classList.contains('-translate-x-full');
            if (isClosed) {
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
                setTimeout(() => overlay.classList.remove('opacity-0'), 10);
            } else {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('opacity-0');
                setTimeout(() => overlay.classList.add('hidden'), 300);
            }
        }

        document.getElementById('openMenuBtn').addEventListener('click', toggleMenu);
        document.getElementById('closeMenuBtn').addEventListener('click', toggleMenu);
        overlay.addEventListener('click', toggleMenu);

        // 2. TIZIM VA ROLLAR LOGIKASI
        const token = localStorage.getItem('hub_token');
        if (!token) window.location.href = '/login';

        let currentUser = null;

        async function initDashboard() {
            try {
                // Profil yuklash
                const userRes = await fetch('/api/users/me', { headers: { 'Authorization': `Bearer ${token}` } });
                if (!userRes.ok) throw new Error();
                currentUser = await userRes.json();

                // Profil UI
                document.getElementById('userNameDisplay').textContent = currentUser.nickname || currentUser.email.split('@')[0];
                document.getElementById('userRoleDisplay').textContent = currentUser.role;

                // Dinamik qismlarni ko'rsatish
                if (currentUser.role === 'STUDENT') {
                    document.getElementById('studentSection').classList.remove('hidden');
                    document.getElementById('addProjectBtn').classList.remove('hidden'); // Talaba loyiha qo'sha oladi
                    // Limitlarni backenddan emas, hozircha UI uchun qattiq (mock) yozyapmiz
                    document.getElementById('profileLimitDisplay').textContent = "2 / 2";
                }
                if (currentUser.role === 'TUTOR') {
                    document.getElementById('tutorSection').classList.remove('hidden');
                }
                if (currentUser.role === 'ADMIN' || currentUser.role === 'LEADER') {
                    document.getElementById('adminSection').classList.remove('hidden');
                }

                // Statistika yuklash
                const statsRes = await fetch('/api/dashboard', { headers: { 'Authorization': `Bearer ${token}` } });
                const stats = await statsRes.json();
                
                document.getElementById('statSpecialists').textContent = stats.generalStats.totalSpecialists;
                document.getElementById('statInMarket').textContent = stats.generalStats.projectStatuses.IN_MARKET || 0;
                document.getElementById('statMvp').textContent = stats.generalStats.projectStatuses.NEED_INVESTMENT || 0;
                document.getElementById('statTeam').textContent = stats.generalStats.projectStatuses.TEAM_BUILDING || 0;

                // Admin/Tutor spetsifik axborotlar...
                if (stats.leaderData && stats.leaderData.canceledProjects.length > 0) {
                    document.getElementById('canceledProjectsBox').innerHTML = stats.leaderData.canceledProjects.map(p => `
                        <div class="mb-4 pb-4 border-b border-darkBorder/50 last:border-0 last:mb-0 last:pb-0">
                            <span class="font-bold text-white text-base">${p.title}</span> <span class="px-2 py-0.5 ml-2 bg-red-500/10 text-red-400 text-[10px] rounded uppercase">${p.status}</span><br>
                            <span class="text-sm mt-1 text-slate-400 block">${p.cancelReason || 'Sabab ko\'rsatilmagan'}</span>
                        </div>
                    `).join('');
                }
                if (stats.tutorData) {
                    document.getElementById('tutorStudentCount').textContent = stats.tutorData.invitedStudentsCount;
                }

            } catch (err) {
                console.log(err);
                logout();
            }
        }

        window.addEventListener('load', initDashboard);

        // 3. TAB ALMASHTIRISH (SILLIQ)
        function switchTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('opacity-100', 'translate-y-0');
                tab.classList.add('opacity-0', 'translate-y-4');
                setTimeout(() => tab.classList.add('hidden'), 300);
            });

            document.querySelectorAll('.nav-btn').forEach(btn => {
                btn.className = "nav-btn w-full flex items-center gap-3 px-4 py-3.5 text-darkTextSub hover:bg-white/5 hover:text-darkTextMain rounded-xl transition-all font-medium text-sm border border-transparent";
            });

            setTimeout(() => {
                const activeTab = document.getElementById(tabId);
                if(activeTab) {
                    activeTab.classList.remove('hidden');
                    setTimeout(() => {
                        activeTab.classList.remove('opacity-0', 'translate-y-4');
                        activeTab.classList.add('opacity-100', 'translate-y-0');
                    }, 50);
                }
            }, 300);
            
            const activeBtn = document.getElementById('nav-' + tabId);
            if(activeBtn) {
                let colorClass = 'blue';
                if(tabId === 'news-tab') colorClass = 'emerald';
                else if(tabId === 'manual-tab') colorClass = 'orange';
                
                activeBtn.className = `nav-btn w-full flex items-center gap-3 px-4 py-3.5 text-${colorClass}-400 bg-${colorClass}-500/10 rounded-xl transition-all font-medium text-sm border border-${colorClass}-500/20`;
                document.getElementById('pageTitle').textContent = activeBtn.textContent.trim();
            }

            if(window.innerWidth < 768) toggleMenu();
        }

        function logout() {
            localStorage.removeItem('hub_token');
            window.location.href = '/login';
        }

        // 4. PWA ENGINE
        let deferredPrompt;
        const installBtn = document.getElementById('pwaInstallBtn');

        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            installBtn.classList.remove('hidden');
            installBtn.classList.add('flex');
        });

        function installPWA() {
            if (deferredPrompt) {
                deferredPrompt.prompt();
                deferredPrompt.userChoice.then((choiceResult) => {
                    if (choiceResult.outcome === 'accepted') {
                        installBtn.classList.add('hidden');
                    }
                    deferredPrompt = null;
                });
            }
        }
    </script>
</body>
</html>
