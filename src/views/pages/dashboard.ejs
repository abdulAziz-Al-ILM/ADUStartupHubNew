<!DOCTYPE html>
<html lang="uz" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ADU Startup Hub - Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        darkBg: '#0b1120',
                        darkCard: '#121928',
                        darkBorder: '#1e293b',
                        darkTextMain: '#e2e8f0',
                        darkTextSub: '#94a3b8'
                    }
                }
            }
        }
    </script>
    <style>
        .bg-grid-pattern {
            background-image: radial-gradient(rgba(148, 163, 184, 0.08) 1px, transparent 1px);
            background-size: 24px 24px;
        }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #334155; }
    </style>
</head>
<body class="bg-darkBg text-darkTextMain font-sans antialiased h-screen flex overflow-hidden selection:bg-blue-500/30">

    <aside class="w-64 bg-darkCard border-r border-darkBorder flex flex-col justify-between hidden md:flex shrink-0 z-20 shadow-2xl relative">
        <div>
            <div class="h-20 flex items-center gap-3 px-6 border-b border-darkBorder bg-darkBg/50 backdrop-blur-md">
                <svg class="w-8 h-8 text-blue-500 drop-shadow-md" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                    <line x1="12" y1="22.08" x2="12" y2="12"></line>
                </svg>
                <span class="font-bold text-lg tracking-tight">Startup Hub</span>
            </div>
            
            <nav class="p-4 space-y-2 mt-2">
                <button onclick="switchTab('main-tab')" id="nav-main-tab" class="nav-btn w-full flex items-center gap-3 px-4 py-3 bg-blue-600/10 text-blue-400 rounded-xl transition-all font-medium text-sm border border-blue-500/20">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                    Asosiy Ko'rsatkichlar
                </button>
                <button onclick="switchTab('projects-tab')" id="nav-projects-tab" class="nav-btn w-full flex items-center gap-3 px-4 py-3 text-darkTextSub hover:bg-white/5 hover:text-darkTextMain rounded-xl transition-all font-medium text-sm border border-transparent">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                    Startap Loyihalar
                </button>
                <button onclick="switchTab('news-tab')" id="nav-news-tab" class="nav-btn w-full flex items-center gap-3 px-4 py-3 text-emerald-500 hover:bg-emerald-500/10 rounded-xl transition-all font-medium text-sm border border-transparent">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path></svg>
                    ILM Mizan Xabarlari
                </button>
            </nav>
        </div>

        <div class="p-4 border-t border-darkBorder bg-darkBg/30 backdrop-blur-sm">
            <div class="flex items-center gap-3 mb-4 p-2 rounded-xl bg-darkCard border border-darkBorder cursor-pointer hover:border-gray-600 transition-colors shadow-sm">
                <div class="w-10 h-10 bg-gradient-to-tr from-blue-600 to-purple-600 rounded-full flex items-center justify-center text-xl shadow-inner border border-white/10">
                    👨‍💻
                </div>
                <div class="overflow-hidden">
                    <p class="text-sm font-bold text-white truncate" id="userNameDisplay">Yuklanmoqda...</p>
                    <p class="text-[11px] text-blue-400 font-semibold truncate uppercase tracking-wider" id="userRoleDisplay">TALABA</p>
                </div>
            </div>
            <button onclick="logout()" class="w-full py-2.5 bg-red-500/10 text-xs font-bold text-red-400 hover:bg-red-500/20 rounded-lg transition-colors border border-red-500/20">
                TIZIMDAN CHIQISH
            </button>
            <p class="text-[10px] text-center text-darkTextSub mt-5 font-semibold tracking-widest uppercase opacity-50">ILM MIZAN ME'MORLIGIDA BUNYOD ETILDI.</p>
        </div>
    </aside>

    <main class="flex-1 flex flex-col relative bg-grid-pattern">
        
        <header class="h-20 flex items-center justify-between px-8 border-b border-darkBorder bg-darkBg/60 backdrop-blur-xl z-10 sticky top-0">
            <h2 id="pageTitle" class="text-xl font-bold tracking-tight text-white">Dashboard</h2>
            
            <button id="pwaInstallBtn" onclick="installPWA()" class="hidden px-5 py-2.5 bg-white text-darkBg hover:bg-gray-200 rounded-xl text-sm font-bold transition-all shadow-[0_0_20px_rgba(255,255,255,0.2)] hover:scale-105 items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                O'rnatish
            </button>
        </header>

        <div class="flex-1 overflow-y-auto p-6 md:p-10 relative z-0">

            <div id="main-tab" class="tab-content transition-all duration-500 opacity-100 translate-y-0">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                    <div class="bg-darkCard border border-darkBorder p-8 rounded-3xl flex flex-col justify-center hover:border-blue-500/50 transition-colors shadow-lg">
                        <span class="text-darkTextSub text-sm font-semibold uppercase tracking-wider mb-2">Jami loyihalar</span>
                        <span class="text-5xl font-black text-white">0</span>
                    </div>
                    <div class="bg-darkCard border border-darkBorder p-8 rounded-3xl flex flex-col justify-center hover:border-emerald-500/50 transition-colors shadow-lg relative overflow-hidden">
                        <div class="absolute right-0 top-0 w-32 h-32 bg-emerald-500/10 rounded-full blur-2xl"></div>
                        <span class="text-darkTextSub text-sm font-semibold uppercase tracking-wider mb-2 relative z-10">Muvaffaqiyatli chiqqan</span>
                        <span class="text-5xl font-black text-emerald-400 relative z-10">0</span>
                    </div>
                    <div class="bg-darkCard border border-darkBorder p-8 rounded-3xl flex flex-col justify-center hover:border-blue-500/50 transition-colors shadow-lg relative overflow-hidden">
                        <div class="absolute right-0 top-0 w-32 h-32 bg-blue-500/10 rounded-full blur-2xl"></div>
                        <span class="text-darkTextSub text-sm font-semibold uppercase tracking-wider mb-2 relative z-10">Platformadagi mutaxassislar</span>
                        <span class="text-5xl font-black text-blue-400 relative z-10">0</span>
                    </div>
                </div>
            </div>

            <div id="projects-tab" class="tab-content hidden opacity-0 translate-y-4 transition-all duration-500">
                <div class="flex items-center justify-between mb-8">
                    <h3 class="text-3xl font-bold text-white tracking-tight">Startap Loyihalar</h3>
                    <button class="px-5 py-2.5 bg-blue-600 text-white font-bold rounded-xl text-sm hover:bg-blue-500 transition-all shadow-[0_0_15px_rgba(37,99,235,0.4)] flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                        Yangi loyiha
                    </button>
                </div>
                <div class="text-center py-24 border border-dashed border-darkBorder bg-darkCard/50 rounded-3xl text-darkTextSub flex flex-col items-center">
                    <svg class="w-16 h-16 text-slate-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
                    <p class="text-lg font-medium text-slate-300">Hozircha hech qanday loyiha yo'q.</p>
                    <p class="text-sm mt-1">Birinchilardan bo'lib o'z startapingizni yarating!</p>
                </div>
            </div>

            <div id="news-tab" class="tab-content hidden opacity-0 translate-y-4 transition-all duration-500">
                <div class="mb-10 border-b border-darkBorder pb-6">
                    <h3 class="text-3xl font-bold text-emerald-400 flex items-center gap-3 tracking-tight">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path></svg>
                        E'lonlar va Yangiliklar
                    </h3>
                    <p class="text-darkTextSub text-base mt-2">Rahbariyat va ILM Mizan markazi tomonidan yuborilgan barcha rasmiy xabarlar.</p>
                </div>

                <div class="flex flex-col gap-6 max-w-4xl">
                    <div class="bg-darkCard border border-darkBorder rounded-3xl p-8 relative overflow-hidden group hover:border-emerald-500/30 transition-colors shadow-lg">
                        <div class="absolute top-0 left-0 w-1.5 h-full bg-gradient-to-b from-emerald-400 to-emerald-600"></div>
                        <div class="flex justify-between items-start mb-5">
                            <span class="px-3 py-1 bg-emerald-500/10 text-emerald-400 text-xs font-bold rounded-lg uppercase tracking-widest border border-emerald-500/20">Muxim e'lon</span>
                            <span class="text-xs font-semibold text-darkTextSub">05 Aprel, 2026</span>
                        </div>
                        <h4 class="text-xl font-bold text-white mb-3">Platforma rasman o'z ishini boshladi!</h4>
                        <p class="text-slate-400 text-base leading-relaxed">
                            Hurmatli talabalar, bugundan e'tiboran ADU Startup Hub yopiq ekotizimi to'liq ishga tushirildi. O'z g'oyalaringizni kiritishingiz va AI yordamida jamoa yig'ishingiz mumkin.
                        </p>
                    </div>

                    <div class="bg-darkCard border border-darkBorder rounded-3xl p-8 relative overflow-hidden group hover:border-blue-500/30 transition-colors shadow-lg">
                        <div class="absolute top-0 left-0 w-1.5 h-full bg-gradient-to-b from-blue-400 to-blue-600"></div>
                        <div class="flex justify-between items-start mb-5">
                            <span class="px-3 py-1 bg-blue-500/10 text-blue-400 text-xs font-bold rounded-lg uppercase tracking-widest border border-blue-500/20">Tizim yangilanishi</span>
                            <span class="text-xs font-semibold text-darkTextSub">01 Aprel, 2026</span>
                        </div>
                        <h4 class="text-xl font-bold text-white mb-3">Sun'iy Intellekt senzurasi faollashdi</h4>
                        <p class="text-slate-400 text-base leading-relaxed">
                            Barcha foydalanuvchilar diqqatiga: xabarlar, loyiha tavsiflari va muammolar bazasi endilikda AI tomonidan to'liq nazorat qilinadi.
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <script>
        const token = localStorage.getItem('hub_token');
        if (!token) {
            window.location.href = '/login';
        }

        function switchTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('opacity-100', 'translate-y-0');
                tab.classList.add('opacity-0', 'translate-y-4');
                setTimeout(() => {
                    tab.classList.add('hidden');
                }, 300);
            });

            document.querySelectorAll('.nav-btn').forEach(btn => {
                btn.className = "nav-btn w-full flex items-center gap-3 px-4 py-3 text-darkTextSub hover:bg-white/5 hover:text-darkTextMain rounded-xl transition-all font-medium text-sm border border-transparent";
            });

            setTimeout(() => {
                const activeTab = document.getElementById(tabId);
                activeTab.classList.remove('hidden');
                setTimeout(() => {
                    activeTab.classList.remove('opacity-0', 'translate-y-4');
                    activeTab.classList.add('opacity-100', 'translate-y-0');
                }, 50);
            }, 300);
            
            const activeBtn = document.getElementById('nav-' + tabId);
            if(tabId === 'news-tab') {
                activeBtn.className = "nav-btn w-full flex items-center gap-3 px-4 py-3 text-emerald-400 bg-emerald-500/10 rounded-xl transition-all font-medium text-sm border border-emerald-500/20";
                document.getElementById('pageTitle').textContent = "ILM Mizan Xabarlari";
            } else if(tabId === 'main-tab') {
                activeBtn.className = "nav-btn w-full flex items-center gap-3 px-4 py-3 bg-blue-600/10 text-blue-400 rounded-xl transition-all font-medium text-sm border border-blue-500/20";
                document.getElementById('pageTitle').textContent = "Dashboard";
            } else {
                activeBtn.className = "nav-btn w-full flex items-center gap-3 px-4 py-3 bg-blue-600/10 text-blue-400 rounded-xl transition-all font-medium text-sm border border-blue-500/20";
                document.getElementById('pageTitle').textContent = "Startap Loyihalar";
            }
        }

        function logout() {
            localStorage.removeItem('hub_token');
            window.location.href = '/login';
        }

        let deferredPrompt;
        const installBtn = document.getElementById('pwaInstallBtn');

        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            installBtn.classList.remove('hidden');
            installBtn.classList.add('flex');
        });

        function installPWA() {
            if (deferredPrompt) {
                deferredPrompt.prompt();
                deferredPrompt.userChoice.then((choiceResult) => {
                    if (choiceResult.outcome === 'accepted') {
                        installBtn.classList.add('hidden');
                    }
                    deferredPrompt = null;
                });
            }
        }
    </script>
</body>
</html>
